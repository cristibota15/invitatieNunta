# ============================================
# SQL pentru crearea tabelei rsvp în Supabase:
# ============================================
#
# CREATE TABLE rsvp (
#   id                    UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   created_at            TIMESTAMPTZ DEFAULT now(),
#   prenume               TEXT NOT NULL,
#   nume                  TEXT NOT NULL,
#   email                 TEXT NOT NULL,
#   telefon               TEXT,
#   participa             BOOLEAN NOT NULL,
#   numar_persoane        INTEGER DEFAULT 1,
#   preferinte_alimentare TEXT,
#   mesaj                 TEXT
# );
#
# -- Row Level Security (opțional, recomandat)
# ALTER TABLE rsvp ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "Oricine poate adăuga RSVP" ON rsvp
#   FOR INSERT TO anon WITH CHECK (true);
